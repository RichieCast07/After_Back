PORT=8000

DB_HOST_LOCAL=localhost
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin
DB_PASS=PasswordDB
DB_SCHEMA=after_db
DB_CONN_LIMIT=10

JWT_SECRET=change-me-to-a-long-random-string

NODE_ENV=development

# CORS_ORIGIN opcional: si no se define, el default permite
# http://localhost:5173 (Vite dev) y https://after.mangelg.space
CORS_ORIGIN=

# Opcionales (WhatsApp vía Twilio) - dejar vacío desactiva el envío, no rompe el arranque
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
SERVER_PUBLIC_URL=http://localhost:8000
